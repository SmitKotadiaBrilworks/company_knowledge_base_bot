# Supabase — get these from: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini — get from: https://aistudio.google.com/app/apikey
# Used for BOTH embeddings (gemini-embedding-001) and answer generation (gemini-2.0-flash)
GEMINI_API_KEY=your-gemini-api-key
